// .\.\apps\api\src\modules\notifications\templates\order-shipped.hbs
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Commande expédiée</title>
</head>
<body style="margin:0;padding:0;background:#f9fafb;font-family:Arial,sans-serif">
  <div style="max-width:600px;margin:40px auto;background:white;border-radius:16px;overflow:hidden;border:1px solid #e5e7eb">

    <!-- Header -->
    <div style="background:#111827;padding:32px;text-align:center">
      <h1 style="color:white;margin:0;font-size:28px">✂️ BarberShop</h1>
      <p style="color:#9ca3af;margin:8px 0 0;font-size:14px">Votre commande est en route !</p>
    </div>

    <!-- Body -->
    <div style="padding:32px">
      <div style="background:#f0fdf4;border:1px solid #86efac;border-radius:12px;padding:16px;margin-bottom:24px">
        <p style="color:#166534;font-weight:bold;margin:0;font-size:16px">
          🚚 Commande expédiée !
        </p>
      </div>

      <p style="color:#374151;font-size:15px">
        Bonjour <strong>{{firstName}}</strong>,
      </p>
      <p style="color:#374151;font-size:15px">
        Bonne nouvelle ! Votre commande <strong>{{orderNumber}}</strong> vient d'être expédiée.
      </p>

      <table style="width:100%;border-collapse:collapse;margin:20px 0">
        <tr style="border-bottom:1px solid #e5e7eb">
          <td style="padding:12px 0;color:#6b7280;font-size:14px;width:40%">Numéro commande</td>
          <td style="padding:12px 0;font-weight:bold;font-size:14px">{{orderNumber}}</td>
        </tr>
        <tr style="border-bottom:1px solid #e5e7eb">
          <td style="padding:12px 0;color:#6b7280;font-size:14px">Date d'expédition</td>
          <td style="padding:12px 0;font-weight:bold;font-size:14px">{{shippedAt}}</td>
        </tr>
        <tr style="border-bottom:1px solid #e5e7eb">
          <td style="padding:12px 0;color:#6b7280;font-size:14px">Montant total</td>
          <td style="padding:12px 0;font-weight:bold;font-size:14px">{{totalAmount}} F CFA</td>
        </tr>
        {{#if trackingNumber}}
        <tr>
          <td style="padding:12px 0;color:#6b7280;font-size:14px">Numéro de suivi</td>
          <td style="padding:12px 0;font-weight:bold;font-size:14px">{{trackingNumber}}</td>
        </tr>
        {{/if}}
      </table>

      <!-- Articles commandés -->
      {{#if items}}
      <h3 style="color:#111827;font-size:16px;margin:24px 0 12px">Articles commandés</h3>
      {{#each items}}
      <div style="display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid #f3f4f6">
        <span style="font-size:14px;color:#374151">{{this.name}} × {{this.quantity}}</span>
        <span style="font-size:14px;font-weight:bold;color:#111827">{{this.price}} F CFA</span>
      </div>
      {{/each}}
      {{/if}}

      <div style="background:#eff6ff;border:1px solid #93c5fd;border-radius:12px;padding:16px;margin:24px 0">
        <p style="color:#1e40af;margin:0;font-size:13px">
          📦 Délai de livraison estimé : <strong>3 à 5 jours ouvrés</strong> en zone UEMOA.
        </p>
      </div>
    </div>

    <!-- Footer -->
    <div style="background:#f9fafb;padding:20px;text-align:center;border-top:1px solid #e5e7eb">
      <p style="color:#9ca3af;font-size:12px;margin:0">
        BarberShop — Produits & Accessoires Professionnels<br>
        Sénégal & Zone UEMOA
      </p>
    </div>
  </div>
</body>
</html>